xfer_b6 = !opc1 & !opc0 & r06 # !opc1 &  opc0 & r16 #  opc1 & !opc0 & r26;
xfer_b7 = !opc1 & !opc0 & r07 # !opc1 &  opc0 & r17 #  opc1 & !opc0 & r27;

reg_we = reg_we_lut # tfr_valid;

w_sel0 = tfr_valid & opc2 # !tfr_valid & w_sel0_lut;
w_sel1 = tfr_valid & opc3 # !tfr_valid & w_sel1_lut;

we_r0 = reg_we & !w_sel1 & !w_sel0;
we_r1 = reg_we & !w_sel1 &  w_sel0;
we_r2 = reg_we &  w_sel1 & !w_sel0;

r00.d = gpr_d0; r01.d = gpr_d1; r02.d = gpr_d2; r03.d = gpr_d3;
r04.d = gpr_d4; r05.d = gpr_d5; r06.d = gpr_d6; r07.d = gpr_d7;
r10.d = gpr_d0; r11.d = gpr_d1; r12.d = gpr_d2; r13.d = gpr_d3;
r14.d = gpr_d4; r15.d = gpr_d5; r16.d = gpr_d6; r17.d = gpr_d7;
r20.d = gpr_d0; r21.d = gpr_d1; r22.d = gpr_d2; r23.d = gpr_d3;
r24.d = gpr_d4; r25.d = gpr_d5; r26.d = gpr_d6; r27.d = gpr_d7;

[r00,r01,r02,r03,r04,r05,r06,r07].ck = clk;
[r10,r11,r12,r13,r14,r15,r16,r17].ck = clk;
[r20,r21,r22,r23,r24,r25,r26,r27].ck = clk;

r00.ce = we_r0; r01.ce = we_r0; r02.ce = we_r0; r03.ce = we_r0;
r04.ce = we_r0; r05.ce = we_r0; r06.ce = we_r0; r07.ce = we_r0;
r10.ce = we_r1; r11.ce = we_r1; r12.ce = we_r1; r13.ce = we_r1;
r14.ce = we_r1; r15.ce = we_r1; r16.ce = we_r1; r17.ce = we_r1;
r20.ce = we_r2; r21.ce = we_r2; r22.ce = we_r2; r23.ce = we_r2;
r24.ce = we_r2; r25.ce = we_r2; r26.ce = we_r2; r27.ce = we_r2;

q_a0 = r00; q_a1 = r01; q_a2 = r02; q_a3 = r03;
q_a4 = r04; q_a5 = r05; q_a6 = r06; q_a7 = r07;
q_b0 = r10; q_b1 = r11; q_b2 = r12; q_b3 = r13;
q_b4 = r14; q_b5 = r15; q_b6 = r16; q_b7 = r17;

gpr_d0 = tfr_valid & xfer_b0 # !tfr_valid & d_in0;
gpr_d1 = tfr_valid & xfer_b1 # !tfr_valid & d_in1;
gpr_d2 = tfr_valid & xfer_b2 # !tfr_valid & d_in2;
gpr_d3 = tfr_valid & xfer_b3 # !tfr_valid & d_in3;
gpr_d4 = tfr_valid & xfer_b4 # !tfr_valid & d_in4;
gpr_d5 = tfr_valid & xfer_b5 # !tfr_valid & d_in5;
gpr_d6 = tfr_valid & xfer_b6 # !tfr_valid & d_in6;
gpr_d7 = tfr_valid & xfer_b7 # !tfr_valid & d_in7;

pc_load_en = macro_end & lut_pc_load & (!lut_pc_flg_z # flg_z);

/* CW_LO pack (control-word-latch.md sec 4) */
cw_lo0 = mem_rd;
cw_lo1 = mem_wr;
cw_lo2 = y_oe;
cw_lo3 = flg_we;
cw_lo4 = pc_load_en;
cw_lo5 = cin;
cw_lo6 = bctrl0;
cw_lo7 = bctrl2;

/* CW_HI pack */
cw_hi0 = lgc0;
cw_hi1 = lgc1;
cw_hi2 = lgc2;
cw_hi3 = lgc3;
cw_hi4 = s0;
cw_hi5 = s1;

cw_data0 = !cw_bank & cw_lo0 # cw_bank & cw_hi0;
cw_data1 = !cw_bank & cw_lo1 # cw_bank & cw_hi1;
cw_data2 = !cw_bank & cw_lo2 # cw_bank & cw_hi2;
cw_data3 = !cw_bank & cw_lo3 # cw_bank & cw_hi3;
cw_data4 = !cw_bank & cw_lo4 # cw_bank & cw_hi4;
cw_data5 = !cw_bank & cw_lo5 # cw_bank & cw_hi5;
cw_data6 = !cw_bank & cw_lo6;
cw_data7 = !cw_bank & cw_lo7;

/* Phase edge detect + 2-cycle CW load (LO then HI) */
ph0_prev.d = ph0;
ph0_prev.ck = clk;
ph1_prev.d = ph1;
ph1_prev.ck = clk;

phase_edge = !macro_end & (ph0 & !ph0_prev # !ph0 & ph0_prev
          # ph1 & !ph1_prev # !ph1 & ph1_prev);

cw_cnt0.d = phase_edge;
cw_cnt0.ck = clk;
cw_cnt1.d = cw_cnt0 & !cw_cnt1;
cw_cnt1.ck = clk;

cw_le = cw_cnt0 # cw_cnt1;
cw_bank = cw_cnt1;
