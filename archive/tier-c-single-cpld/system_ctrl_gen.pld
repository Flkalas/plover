tfr_valid = opcode : 'b'10001 # opcode : 'b'10010 # opcode : 'b'10100
          # opcode : 'b'10110 # opcode : 'b'11000 # opcode : 'b'11001;

/* 3-way src mux: opc[1:0] -> R0/R1/R2 read (used only when tfr_valid) */
xfer_b0 = !opc1 & !opc0 & r00 # !opc1 &  opc0 & r10 #  opc1 & !opc0 & r20;
xfer_b1 = !opc1 & !opc0 & r01 # !opc1 &  opc0 & r11 #  opc1 & !opc0 & r21;
xfer_b2 = !opc1 & !opc0 & r02 # !opc1 &  opc0 & r12 #  opc1 & !opc0 & r22;
xfer_b3 = !opc1 & !opc0 & r03 # !opc1 &  opc0 & r13 #  opc1 & !opc0 & r23;
xfer_b4 = !opc1 & !opc0 & r04 # !opc1 &  opc0 & r14 #  opc1 & !opc0 & r24;
