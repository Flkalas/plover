 34:
 35:/* Outputs unpinned - fitter assigns PLCC pads; export system_ctrl.pin after fit */
 36:
 37:/* Buried state */
 38:Pinnode [0..0] = [ph0,ph1];
 39:Pinnode [0..0] = [r00,r01,r02,r03,r04,r05,r06,r07];
 40:Pinnode [0..0] = [r10,r11,r12,r13,r14,r15,r16,r17];
