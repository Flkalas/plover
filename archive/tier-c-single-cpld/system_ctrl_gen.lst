112:/* 3-way src mux: opc[1:0] -> R0/R1/R2 read (used only when tfr_valid) */
113:xfer_b0 = !opc1 & !opc0 & r00 # !opc1 &  opc0 & r10 #  opc1 & !opc0 & r20;
114:xfer_b1 = !opc1 & !opc0 & r01 # !opc1 &  opc0 & r11 #  opc1 & !opc0 & r21;
