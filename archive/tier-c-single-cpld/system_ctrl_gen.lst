 43:Pinnode [0..0] = [w_sel0,w_sel1,macro_end,flg_we];
 44:
 45:FIELD opcode = [opc4, opc3, opc2, opc1, opc0];
 46:
 47:ph0.d = !macro_end & !ph0;
 48:ph1.d = !macro_end & (ph1 # ph0);
 49:ph0.ck = clk;
 50:ph1.ck = clk;
 51:
 52:end_ph1 = opcode : 'b'00001 # opcode : 'b'01101;
 53:end_ph0 = opcode : 'b'00010 # opcode : 'b'00011 # opcode : 'b'00100

